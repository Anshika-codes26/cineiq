# ==========================================
# CINEIQ — Environment Variables Template
# ==========================================

# ─── API Keys (REPLACE THESE) ───
# Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=REPLACE_WITH_YOUR_KEY
CLERK_SECRET_KEY=REPLACE_WITH_YOUR_KEY

# External Data & LLM
TMDB_API_KEY=REPLACE_WITH_YOUR_KEY
GROQ_API_KEY=REPLACE_WITH_YOUR_KEY

# ─── Application Settings ───
ENVIRONMENT=development
BACKEND_CORS_ORIGINS=["http://localhost:3000"]
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8001

# ─── Database & Storage ───
POSTGRES_USER=cineiq
POSTGRES_PASSWORD=cineiq_secret
POSTGRES_DB=cineiq
DATABASE_URL=postgresql+asyncpg://cineiq:cineiq_secret@postgres_cineiq:5432/cineiq

REDIS_URL=redis://redis_cineiq:6379/0

QDRANT_HOST=qdrant_cineiq
QDRANT_PORT=6333

MINIO_ROOT_USER=cineiq_admin
MINIO_ROOT_PASSWORD=cineiq_secret
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=cineiq-assets

# ─── Observability ───
LOKI_URL=http://loki_cineiq:3100/loki/api/v1/push
